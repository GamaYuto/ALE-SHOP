{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "target": "vittoria-target",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "X-Frame-Options", "value": "DENY" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
            { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
            { "key": "Content-Security-Policy", "value": "default-src 'self' https://*.firebaseio.com https://*.googleapis.com https://*.gstatic.com; script-src 'self' https://*.firebaseapp.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:;" }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/api/**",
          "destination": "/404.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "site": "ale-shop-7b472",
      "redirects": [
        {
          "source": "**",
          "destination": "https://vittoriajoyas.web.app",
          "type": 301
        }
      ]
    }
  ]
}